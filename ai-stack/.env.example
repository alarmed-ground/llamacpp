# =============================================================================
# .env – copy this to .env and fill in your values
# Generate secrets with: openssl rand -hex 32
# =============================================================================

# Open WebUI
WEBUI_SECRET_KEY=changeme-replace-with-openssl-rand-hex-32-output

# SearXNG
SEARXNG_SECRET_KEY=changeme-replace-with-openssl-rand-hex-32-output

# llama.cpp server (only used with --profile llama-cpp)
# Filename of your GGUF model inside the llama_models volume / ./models/ folder
LLAMA_MODEL=your-model.Q4_K_M.gguf
# Number of layers to offload to GPU (0 = CPU only, 999 = all layers on GPU)
LLAMA_GPU_LAYERS=0
# CPU threads for inference
LLAMA_THREADS=4
